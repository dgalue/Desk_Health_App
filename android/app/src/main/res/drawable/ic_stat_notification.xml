<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon for Desk Health.
    MUST be white-on-transparent (monochrome) — Android tints this automatically.
    Represents a simple timer/clock face matching the app's focus-timer theme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Clock circle outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:pathData="M12,2 A10,10 0 1,1 11.999,2 Z" />

    <!-- Hour hand (12 → 12 position, pointing up) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M12,6 L12,12" />

    <!-- Minute hand (pointing to 3 o'clock) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M12,12 L16,14" />

</vector>
